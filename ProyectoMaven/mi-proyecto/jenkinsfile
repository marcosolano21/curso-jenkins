pipeline{
    agent any
    stages{
        stage('Build'){
            steps{
                sh 'cd ProyectoMaven/mi-proyecto && mvn clean install'                
            }
        }

        stage('Test'){
            steps{
                sh 'mvn test'                
            }
        }

        stage('Deploy'){
            steps{
                echo "Simulando un deployment de un servidor de aplicaciones"
            }
        }
    }

    post{
        always{
            echo "Siempre se ejecuta"
        }

        success{
            echo "Este bloque se ejecuta si todo el pipeline se ejecuta correctamente"
        }

        failure{
            echo "Este bloque se ejecuta si el pipeline falla"
        }
    }
}